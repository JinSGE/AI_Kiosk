# OpenAI API Key (required for GPT features)
OPENAI_API_KEY=your-openai-api-key-here

# Debug mode (True/False)
DEBUG=True

# CORS allowed origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]

# TTS Engine: gtts or coqui
TTS_MODEL_PATH=gtts

# STT Engine: google or whisper
STT_MODEL_PATH=google

# Optional: GPU settings
USE_GPU=True
USE_8BIT_QUANTIZATION=False
GPU_MEMORY_LIMIT=0.9

# Optional model config
MAX_TEXT_LENGTH=1024
TTS_SAMPLING_RATE=24000
MAX_AUDIO_LENGTH_SECONDS=300

# Kiosk system prompt
KIOSK_SYSTEM_PROMPT="당신은 카페 키오스크 시스템입니다. 고객의 주문을 정확히 확인하고 자연스럽게 응답하세요."

# Proxy (leave blank if not using)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=*
